Find the Count of Numbers Which Are Not Special.

Method used is called Sieve of Eratosthenes


class Solution {
public:
    int nonSpecialCount(int l, int r) {
        // Calculate the square root of r
        int lim = static_cast<int>(sqrt(r));

        // Create a boolean vector for marking primes up to lim
        vector<bool> isPrime(lim + 1, true);

        // Mark 0 and 1 as non-prime
        isPrime[0] = isPrime[1] = false;

        // Use Sieve of Eratosthenes to find all primes up to lim
        for (int i = 2; i * i <= lim; ++i) {
            if (isPrime[i]) {
                for (int j = i * i; j <= lim; j += i) {
                    isPrime[j] = false;
                }
            }
        }

        // Count the number of perfect squares of primes within the range [l, r]
        int count = 0;
        for (int i = 2; i <= lim; ++i) {
            if (isPrime[i]) {
                int square = i * i;
                if (square >= l && square <= r) {
                    count++;
                }
            }
        }

        // Total numbers in the range [l, r]
        int totalNumbers = r - l + 1;

        // Return the count of non-special numbers
        return totalNumbers - count;
    }
};


Time Complexity = Nlog(logN)

